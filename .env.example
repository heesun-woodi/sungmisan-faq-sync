# 로컬 테스트용 예시. 이 파일을 복사해 .env 로 만들고 값을 채우세요.
# (.env 는 .gitignore 로 커밋되지 않습니다. GitHub에서는 이 값들을 Repository Secrets 로 등록합니다.)

# 노션 Internal Integration 토큰 (notion.so/my-integrations 에서 발급)
NOTION_TOKEN=

# 노션 FAQ 페이지 ID — 페이지 URL 의 32자리 hex
#   예) https://www.notion.so/.../33624e50d05480a984aaf6ddc5ae34ff?v=... → 33624e50d05480a984aaf6ddc5ae34ff
NOTION_ROOT_PAGE_ID=
